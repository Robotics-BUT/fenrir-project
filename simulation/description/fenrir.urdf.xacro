<?xml version="1.0"?>
<!--
  Fenrir robot description for Gazebo Harmonic + ROS 2 Jazzy (Phase 4).

  Dimensions per spec confirmed by Adam Ligocki 2026-05-20:
    * chassis     : 15 × 15 × 15 cm cube
    * wheelbase   : 12 cm (interwheel)
    * wheel       : 33 mm radius (66 mm diameter)
    * lidar       : XY-center of the robot, on top of the chassis
    * camera      : RPi camera, front-top of chassis, pitched 45° down
    * ultrasounds : 3× — forward, +45° left, -45° right, mid-height
  Wheel width, motor / caster mass, and other masses remain estimates;
  refine from the editable SolidWorks CAD in bpc-prp-devel/hw_design/.

  Coordinate convention: +x forward, +y left, +z up. SI units (m, kg, s, rad).
  base_link origin sits at wheel-axle level; chassis bottom sits at base_link z=0.
-->
<robot name="fenrir" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================== -->
  <!--  Dimensions                                                     -->
  <!-- ============================================================== -->
  <xacro:property name="chassis_length" value="0.15"/>     <!-- m  -->
  <xacro:property name="chassis_width"  value="0.15"/>     <!-- m  -->
  <xacro:property name="chassis_height" value="0.15"/>     <!-- m  -->
  <xacro:property name="chassis_mass"   value="1.0"/>       <!-- kg, estimate -->

  <xacro:property name="wheel_radius"        value="0.033"/>  <!-- m, spec; STL 34mm -->
  <xacro:property name="wheel_width"         value="0.030"/>  <!-- m, from wheel.STL -->
  <xacro:property name="wheel_mass"          value="0.05"/>    <!-- kg, estimate -->
  <xacro:property name="wheel_separation"    value="0.12"/>    <!-- m, interwheel -->
  <xacro:property name="wheel_axle_x_offset" value="0.0"/>     <!-- m, axle vs base origin -->
  <xacro:property name="wheel_axle_z_offset" value="0.0"/>     <!-- m, axle height vs base origin -->

  <!-- Real Fenrir has a FRONT skid (leg_front_2.STL) and a REAR support +
       ball caster (leg_rear_2.STL + ball_2.STL). With a 15 cm chassis the
       camera weight up front would tip the robot if it only had a rear
       caster, so the sim mirrors the design with two passive casters. -->
  <xacro:property name="caster_radius" value="0.012"/>     <!-- m  -->
  <xacro:property name="caster_mass"   value="0.01"/>      <!-- kg -->
  <xacro:property name="caster_front_x" value="0.065"/>    <!-- m, near front of 15cm chassis -->
  <xacro:property name="caster_rear_x"  value="-0.065"/>   <!-- m, near rear of 15cm chassis -->

  <!-- ===== Sensor placements (all relative to base_link) ===== -->
  <!-- LiDAR: XY-center, on TOP of chassis with a small mount stub. -->
  <xacro:property name="lidar_x"      value="0.0"/>
  <xacro:property name="lidar_y"      value="0.0"/>
  <xacro:property name="lidar_z"      value="${chassis_height + 0.020}"/>

  <!-- Camera: front-top of chassis, pitched 45° down toward floor.
       At z=chassis_height the camera sits at the top edge. Pitch = +π/4
       rotates the camera_link's +x (gz "forward") down by 45°. -->
  <xacro:property name="camera_x"     value="${chassis_length/2.0}"/>
  <xacro:property name="camera_z"     value="${chassis_height}"/>
  <xacro:property name="camera_pitch" value="${pi/4.0}"/>

  <!-- Ultrasounds: all at mid-chassis-height. Sensors stick out 5 mm
       past the front face so the gpu_lidar raycast does not start inside
       the chassis collision volume (which would clamp it to min_range).
       Left/right sit at the front-left and front-right corners. -->
  <xacro:property name="us_x"          value="${chassis_length/2.0 + 0.005}"/>
  <xacro:property name="us_z"          value="${chassis_height/2.0}"/>
  <xacro:property name="us_side_y"     value="${chassis_width/2.0 - 0.010}"/>  <!-- near chassis corner -->
  <xacro:property name="us_side_yaw"   value="${pi/4.0}"/>       <!-- 45° -->

  <!-- Line sensors sit at the front-leg X (same x as caster_front), centered
       laterally; the floor_camera then samples two pixel positions that
       correspond to "slightly left" and "slightly right" of the leg. -->
  <xacro:property name="line_sensor_x" value="${caster_front_x}"/>
  <xacro:property name="line_sensor_z" value="-0.01"/>

  <!-- Encoder spec from MODERNIZATION_ROADMAP Appendix B. -->
  <xacro:property name="encoder_pulses_per_rev" value="576"/>

  <!-- ============================================================== -->
  <!--  Inertial helper macros                                         -->
  <!-- ============================================================== -->
  <xacro:macro name="box_inertia" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass*(y*y + z*z)/12.0}" ixy="0" ixz="0"
        iyy="${mass*(x*x + z*z)/12.0}" iyz="0"
        izz="${mass*(x*x + y*y)/12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="mass radius length">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass*(3*radius*radius + length*length)/12.0}" ixy="0" ixz="0"
        iyy="${mass*(3*radius*radius + length*length)/12.0}" iyz="0"
        izz="${mass*radius*radius/2.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="mass radius">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${2.0*mass*radius*radius/5.0}" ixy="0" ixz="0"
        iyy="${2.0*mass*radius*radius/5.0}" iyz="0"
        izz="${2.0*mass*radius*radius/5.0}"/>
    </inertial>
  </xacro:macro>

  <!-- ============================================================== -->
  <!--  base_link — chassis                                            -->
  <!-- ============================================================== -->
  <link name="base_footprint"/>
  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <!-- shift up so chassis BOTTOM = base_link z=0 (axle plane). -->
      <origin xyz="0 0 ${chassis_height/2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="grey">
        <color rgba="0.4 0.4 0.4 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${chassis_height/2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <!-- Inertial origin must sit at the chassis CoM, not at base_link. -->
    <inertial>
      <origin xyz="0 0 ${chassis_height/2.0}" rpy="0 0 0"/>
      <mass value="${chassis_mass}"/>
      <inertia
        ixx="${chassis_mass*(chassis_width*chassis_width + chassis_height*chassis_height)/12.0}" ixy="0" ixz="0"
        iyy="${chassis_mass*(chassis_length*chassis_length + chassis_height*chassis_height)/12.0}" iyz="0"
        izz="${chassis_mass*(chassis_length*chassis_length + chassis_width*chassis_width)/12.0}"/>
    </inertial>
  </link>

  <!-- ============================================================== -->
  <!--  Driven wheels (left, right)                                    -->
  <!-- ============================================================== -->
  <xacro:macro name="wheel" params="side reflect">
    <link name="${side}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2.0} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black">
          <color rgba="0.05 0.05 0.05 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2.0} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia mass="${wheel_mass}"
                              radius="${wheel_radius}" length="${wheel_width}"/>
    </link>

    <joint name="${side}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${side}_wheel_link"/>
      <origin xyz="${wheel_axle_x_offset} ${reflect*wheel_separation/2.0} ${wheel_axle_z_offset}"
              rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.001" friction="0.0"/>
    </joint>

    <gazebo reference="${side}_wheel_link">
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
    </gazebo>
  </xacro:macro>

  <xacro:wheel side="left"  reflect="1"/>
  <xacro:wheel side="right" reflect="-1"/>

  <!-- ============================================================== -->
  <!--  Casters (front + rear) — passive stabilizers                  -->
  <!-- ============================================================== -->
  <xacro:macro name="caster" params="suffix x">
    <link name="caster_${suffix}_link">
      <visual>
        <geometry><sphere radius="${caster_radius}"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_radius}"/></geometry>
      </collision>
      <xacro:sphere_inertia mass="${caster_mass}" radius="${caster_radius}"/>
    </link>
    <joint name="caster_${suffix}_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="caster_${suffix}_link"/>
      <origin xyz="${x} 0 ${-(wheel_radius - caster_radius)}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="caster_${suffix}_link">
      <mu1>0.05</mu1>
      <mu2>0.05</mu2>
    </gazebo>
  </xacro:macro>

  <xacro:caster suffix="front" x="${caster_front_x}"/>
  <xacro:caster suffix="rear"  x="${caster_rear_x}"/>

  <!-- ============================================================== -->
  <!--  Lidar (RPLiDAR A1 — 360° 2D scan)                             -->
  <!-- ============================================================== -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.1" radius="0.035" length="0.04"/>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="${lidar_x} ${lidar_y} ${lidar_z}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="lidar_link">
    <sensor name="rplidar_a1" type="gpu_lidar">
      <topic>lidar</topic>
      <update_rate>12</update_rate>  <!-- Hz; matches real RPLiDAR A1 -->
      <gz_frame_id>lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>${-pi}</min_angle>
            <max_angle>${pi}</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- ============================================================== -->
  <!--  Camera (640x480 @ 30 Hz, bgr8 — matches Appendix B)            -->
  <!-- ============================================================== -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.02 0.04 0.03"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.04 0.03"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="0.05" x="0.02" y="0.04" z="0.03"/>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <!-- Front-top of chassis, pitched 45° down toward the ground. -->
    <origin xyz="${camera_x} 0 ${camera_z}" rpy="0 ${camera_pitch} 0"/>
  </joint>

  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2.0} 0 ${-pi/2.0}"/>
  </joint>

  <gazebo reference="camera_link">
    <sensor name="rgb_camera" type="camera">
      <topic>camera</topic>
      <gz_frame_id>camera_optical_frame</gz_frame_id>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>  <!-- ~60 deg, refine -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>10.0</far>
        </clip>
      </camera>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- ============================================================== -->
  <!--  IMU (MPU6050 — 100 Hz)                                         -->
  <!-- ============================================================== -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
  </joint>
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <topic>imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><stddev>0.005</stddev></noise></x>
          <y><noise type="gaussian"><stddev>0.005</stddev></noise></y>
          <z><noise type="gaussian"><stddev>0.005</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><stddev>0.02</stddev></noise></x>
          <y><noise type="gaussian"><stddev>0.02</stddev></noise></y>
          <z><noise type="gaussian"><stddev>0.02</stddev></noise></z>
        </linear_acceleration>
      </imu>
      <always_on>true</always_on>
    </sensor>
  </gazebo>

  <!-- ============================================================== -->
  <!--  Ultrasounds (3× SRF-05-like)                                   -->
  <!--                                                                 -->
  <!--  Forward, +45° left, -45° right. All at mid-chassis height.    -->
  <!--  Gazebo Harmonic has no native sonar primitive, so we model    -->
  <!--  each one as a narrow gpu_lidar fan spanning ±30°. The         -->
  <!--  ultrasound_bridge node takes the MINIMUM distance across the  -->
  <!--  fan per sensor — mirroring real-US echo behaviour: the sensor -->
  <!--  reports the closest reflector inside its beam. Real-spec       -->
  <!--  range 2 cm — 255 cm, per Adam 2026-05-27.                      -->
  <!--                                                                 -->
  <!--  The bridge aggregates the three /us_* topics into a            -->
  <!--  std_msgs/UInt8MultiArray of 3 distances in cm, matching the   -->
  <!--  /bpc_prp_robot/ultrasounds contract in Appendix B.            -->
  <!-- ============================================================== -->
  <xacro:property name="us_half_fov"    value="${pi/6.0}"/>  <!-- ±30° -->
  <xacro:property name="us_fan_samples" value="31"/>          <!-- ≈2°/ray -->

  <xacro:macro name="ultrasound" params="suffix x y yaw">
    <!-- Sensor link is a 2x2x1 cm visual marker only — no collision so
         the sensor's own model does not occlude the raycast. -->
    <link name="us_${suffix}_link">
      <visual>
        <geometry><box size="0.02 0.02 0.01"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <xacro:box_inertia mass="0.005" x="0.02" y="0.02" z="0.01"/>
    </link>
    <joint name="us_${suffix}_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="us_${suffix}_link"/>
      <origin xyz="${x} ${y} ${us_z}" rpy="0 0 ${yaw}"/>
    </joint>

    <gazebo reference="us_${suffix}_link">
      <sensor name="ultrasound_${suffix}" type="gpu_lidar">
        <topic>us_${suffix}</topic>
        <gz_frame_id>us_${suffix}_link</gz_frame_id>
        <update_rate>5</update_rate>  <!-- 5 Hz per Appendix B -->
        <lidar>
          <scan>
            <horizontal>
              <samples>${us_fan_samples}</samples>
              <min_angle>${-us_half_fov}</min_angle>
              <max_angle>${us_half_fov}</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.02</min>
            <max>2.55</max>  <!-- 255 cm max (UInt8 cap) -->
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.005</stddev>
          </noise>
        </lidar>
        <always_on>true</always_on>
      </sensor>
    </gazebo>
  </xacro:macro>

  <xacro:ultrasound suffix="front" x="${us_x}"
                    y="0"                  yaw="0"/>
  <xacro:ultrasound suffix="left"  x="${us_x}"
                    y="${us_side_y}"       yaw="${us_side_yaw}"/>
  <xacro:ultrasound suffix="right" x="${us_x}"
                    y="${-us_side_y}"      yaw="${-us_side_yaw}"/>

  <!-- ============================================================== -->
  <!--  Line sensors (T4.2)                                            -->
  <!--                                                                 -->
  <!--  The real Fenrir has 2 analog IR line sensors pointing down.   -->
  <!--  No native Gazebo "line sensor" exists, so we simulate them as -->
  <!--  a small downward-facing camera that the line_sensor_bridge    -->
  <!--  node samples at two pixel positions. The bridge publishes      -->
  <!--  /bpc_prp_robot/line_sensors as UInt16MultiArray[2] in the      -->
  <!--  0..1023 range, matching the real ADC. Polarity: white floor   -->
  <!--  -> high reading, black line -> low reading (linear in pixel    -->
  <!--  brightness).                                                   -->
  <!--                                                                 -->
  <!--  The camera image itself is bridged as /internal/floor_camera; -->
  <!--  students should not subscribe to it directly.                  -->
  <!-- ============================================================== -->
  <link name="line_sensor_link"/>
  <joint name="line_sensor_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="line_sensor_link"/>
    <origin xyz="${line_sensor_x} 0 ${line_sensor_z}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="line_sensor_link">
    <sensor name="floor_camera" type="camera">
      <topic>internal/floor_camera</topic>
      <gz_frame_id>line_sensor_link</gz_frame_id>
      <update_rate>30</update_rate>
      <!-- Rotate the sensor so its optical +x (camera forward in gz)
           points straight down (-z of line_sensor_link). -->
      <pose>0 0 0 0 ${pi/2.0} 0</pose>
      <camera>
        <horizontal_fov>1.5708</horizontal_fov>  <!-- 90 deg -->
        <image>
          <width>64</width>
          <height>32</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.001</near>
          <far>0.5</far>
        </clip>
      </camera>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- ============================================================== -->
  <!--  RGB status LEDs (4×, on top: front / right / back / left)      -->
  <!--                                                                 -->
  <!--  Real Fenrir carries a 4-element NeoPixel strip on the chassis  -->
  <!--  top, driven by /bpc_prp_robot/rgb_leds (UInt8MultiArray, 12    -->
  <!--  values = 4 × RGB, each 0–255). In sim the 4 LEDs sit at the    -->
  <!--  four edge midpoints of the top plate so each faces a compass   -->
  <!--  direction; the data layout is left-to-right per LED:           -->
  <!--      data[0:3]  -> front  (+x)                                   -->
  <!--      data[3:6]  -> right  (-y)                                   -->
  <!--      data[6:9]  -> back   (-x)                                   -->
  <!--      data[9:12] -> left   (+y)                                   -->
  <!--                                                                 -->
  <!--  These links give the LEDs physical presence in the Gazebo      -->
  <!--  scene. Live colour is rendered by the rgb_leds_bridge node as   -->
  <!--  RViz markers overlaid at these same positions (gz-sim 8.11 has  -->
  <!--  no runtime material-colour system).                            -->
  <!-- ============================================================== -->
  <xacro:property name="led_size"   value="0.020"/>
  <xacro:property name="led_height" value="0.012"/>
  <xacro:property name="led_offset" value="0.060"/>   <!-- centre -> edge -->
  <xacro:property name="led_z"      value="${chassis_height + led_height/2.0}"/>

  <xacro:macro name="rgb_led" params="name x y color:='0.12 0.12 0.12 1.0'">
    <link name="led_${name}_link">
      <!-- Visual name "led_${name}" is what the LedMaterialColor system
           matches on to recolour this cube at runtime. `color` sets the
           startup colour (overridden live by /bpc_prp_robot/rgb_leds). -->
      <visual name="led_${name}">
        <geometry><box size="${led_size} ${led_size} ${led_height}"/></geometry>
        <material name="led_${name}_mat">
          <color rgba="${color}"/>
        </material>
      </visual>
      <xacro:box_inertia mass="0.002" x="${led_size}" y="${led_size}" z="${led_height}"/>
    </link>
    <joint name="led_${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="led_${name}_link"/>
      <origin xyz="${x} ${y} ${led_z}" rpy="0 0 0"/>
    </joint>
    <!-- Keep the LED as its own link/visual (do not lump into base_link)
         so the visual keeps a clean, matchable name in Gazebo. -->
    <gazebo reference="led_${name}_joint">
      <preserveFixedJoint>true</preserveFixedJoint>
      <disableFixedJointLumping>true</disableFixedJointLumping>
    </gazebo>
  </xacro:macro>

  <xacro:rgb_led name="front" x="${led_offset}"  y="0"/>
  <xacro:rgb_led name="right" x="0"              y="${-led_offset}"/>
  <xacro:rgb_led name="back"  x="${-led_offset}" y="0"/>
  <xacro:rgb_led name="left"  x="0"              y="${led_offset}"/>

  <!-- ============================================================== -->
  <!--  Diff-drive system plugin (Gazebo Harmonic gz::sim::systems)    -->
  <!--                                                                 -->
  <!--  Publishes the gz topic /model/fenrir/cmd_vel <- Twist input.   -->
  <!--  The motor_bridge node converts /bpc_prp_robot/set_motor_speeds -->
  <!--  (uint8[2], 127=stop, 1s watchdog) into that Twist.             -->
  <!--                                                                 -->
  <!--  Also publishes joint states for the wheels (encoder source).   -->
  <!-- ============================================================== -->
  <!--
    Model-level Gazebo plugins. World-level systems (Sensors, Physics,
    SceneBroadcaster, UserCommands, Imu) live in worlds/*.sdf instead.
  -->
  <gazebo>
    <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <tf_topic>tf</tf_topic>
    </plugin>

    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>

    <!-- Recolours the 4 LED cubes (led_front/right/back/left) at runtime
         from gz.msgs.MaterialColor on /led_colors. The rgb_leds_bridge
         node feeds it from /bpc_prp_robot/rgb_leds via ros_gz_bridge.
         Needs libLedMaterialColor.so on GZ_SIM_SYSTEM_PLUGIN_PATH. -->
    <plugin filename="LedMaterialColor" name="fenrir_sim::LedMaterialColor">
      <topic>/led_colors</topic>
    </plugin>
  </gazebo>

</robot>
